SIMULATOR=1
DEVICE_ID=PG-DEV-0001
API_URL=https://your-cloud-endpoint.example.com/ingest
API_KEY=CHANGE_ME
SQLITE_PATH=./dev.db
LOG_DIR=./logs
I2C_BUS=1
ADS1115_ADDR=0x48
NPK_PORT=/dev/ttyUSB0
NPK_BAUD=9600
NPK_SLAVE=1
W1_PATH=/sys/bus/w1/devices

# Neptune cloud uplink (monitoring backend)
NEPTUNE_API_URL=https://your-monitoring-endpoint.example.com/api/v1/ingest
NEPTUNE_API_KEY=replace-me
NEPTUNE_ENABLED=1
